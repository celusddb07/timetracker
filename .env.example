# Copy this file to .env and fill in the values for local development.

# PostgreSQL connection string (Render sets this automatically from the add-on)
DATABASE_URL=postgresql://user:password@localhost:5432/timetracker

# Password that protects the app — choose something strong
APP_PASSWORD=changeme

# Random secret used to sign the session cookie — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-string
